#!/bin/sh
# divvy — splits the terminal into: files (yazi) | editor | agent  +  terminal
# Built on zellij. Pick the editor and agent with flags.
set -e

# --- resolve the real project directory (follow symlinks) ---
SELF="$0"
while [ -L "$SELF" ]; do
    L="$(readlink "$SELF")"
    case "$L" in
        /*) SELF="$L" ;;
        *)  SELF="$(dirname "$SELF")/$L" ;;
    esac
done
DIR="$(cd "$(dirname "$SELF")" && pwd)"

EDITOR_CHOICE="nvim"
AGENT_CHOICE="claude"
THEME_CHOICE=""
DRY_RUN=0

usage() {
    cat <<EOF
divvy — files (yazi) | editor | agent  +  terminal at the bottom

Usage:
  divvy [options]

Options:
  -e, --editor <nvim|helix|micro|vim>    Center editor          (default: nvim)
  -a, --agent  <command>                 Right-hand agent       (default: claude)
                                         Suggested: claude, codex, opencode,
                                         aider, agy, goose. Accepts any command
                                         you have installed.
  -t, --theme  <dracula|catppuccin|tokyonight|gruvbox|nord>  Set the theme and launch
  -l, --list                             List editors/agents/themes
      --dry-run                          Generate the layout and print it (don't launch)
  -h, --help                             This help

Examples:
  divvy
  divvy --editor helix --agent opencode
  divvy -e nvim -a codex
  divvy -a my-custom-agent
EOF
}

while [ $# -gt 0 ]; do
    case "$1" in
        -e|--editor) EDITOR_CHOICE="$2"; shift 2 ;;
        -a|--agent)  AGENT_CHOICE="$2";  shift 2 ;;
        -t|--theme)  THEME_CHOICE="$2";  shift 2 ;;
        -l|--list)   echo "Editors:   nvim, helix, micro, vim"; echo "Agents:    claude, codex, opencode, aider, agy, goose (or any command)"; echo "Themes:    dracula, catppuccin, tokyonight, gruvbox, nord"; echo "Terminals: ghostty, wezterm, kitty, alacritty (themed automatically; runs in any)"; exit 0 ;;
        --dry-run)   DRY_RUN=1; shift ;;
        -h|--help)   usage; exit 0 ;;
        *) echo "Unknown option: $1" >&2; usage; exit 1 ;;
    esac
done

case "$EDITOR_CHOICE" in
    nvim|helix|micro|vim) ;;
    *) echo "Invalid editor: '$EDITOR_CHOICE' (use nvim|helix|micro|vim)" >&2; exit 1 ;;
esac
# The agent can be any command (bring-your-own); we only check it isn't empty.
[ -z "$AGENT_CHOICE" ] && { echo "Empty agent. Use -a <command> (e.g. claude, codex, agy…)" >&2; exit 1; }

# apply the theme if one was requested
if [ -n "$THEME_CHOICE" ]; then
    divvy-theme "$THEME_CHOICE"
fi

# warn if a binary is missing (doesn't abort)
ed_bin="$EDITOR_CHOICE"; [ "$EDITOR_CHOICE" = helix ] && ed_bin=hx
command -v "$ed_bin"      >/dev/null 2>&1 || echo "WARNING: '$ed_bin' is not installed; the editor pane will show an error." >&2
command -v "$AGENT_CHOICE" >/dev/null 2>&1 || echo "WARNING: '$AGENT_CHOICE' is not installed; the agent pane will show an error." >&2

# clean up leftovers from previous divvy sessions (sockets/fifos and orphan nvim)
divvy-clean >/dev/null 2>&1 || true

# --- generate the layout ---
RUNTIME="$DIR/.runtime"
mkdir -p "$RUNTIME"
LAYOUT="$RUNTIME/layout.kdl"
YAZIDIR="$DIR/yazi"

cat > "$LAYOUT" <<EOF
// Generated by divvy  (editor=$EDITOR_CHOICE  agent=$AGENT_CHOICE)
layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    tab name="divvy" focus=true {
        pane size="80%" split_direction="vertical" {
            pane size="25%" {
                name "files"
                command "sh"
                args "-c" "DIVVY_EDITOR=$EDITOR_CHOICE YAZI_CONFIG_HOME=$YAZIDIR yazi"
            }
            pane {
                name "editor"
                command "sh"
                args "-c" "DIVVY_EDITOR=$EDITOR_CHOICE divvy-edit"
            }
            pane size="33%" {
                name "$AGENT_CHOICE"
                command "$AGENT_CHOICE"
            }
        }
        pane size="20%" {
            name "terminal"
        }
    }
}
EOF

if [ "$DRY_RUN" = "1" ]; then
    echo "Layout generated at: $LAYOUT"
    echo "----------------------------------------"
    cat "$LAYOUT"
    exit 0
fi

exec zellij -c "$DIR/zellij/config.kdl" --layout "$LAYOUT"
