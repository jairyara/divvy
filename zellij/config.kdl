// Config de zellij SOLO para divvy (se pasa con -c al lanzar).
//
// Clave del problema de "procesos zombie": por defecto zellij, al recibir
// SIGHUP/SIGTERM (p.ej. al cerrar Ghostty), hace DETACH y deja la sesion —con
// nvim, yazi y el agente— viva en segundo plano. Sesion tras sesion se
// acumulan. Con "quit" la sesion se cierra del todo y mata a sus procesos.
on_force_close "quit"

// Tampoco serializamos/resucitamos sesiones divvy: cada lanzamiento es limpio.
session_serialization false

// --- Saltar a un panel por numero ---------------------------------------
// zellij 0.44 NO tiene "foco por indice/nombre"; solo foco direccional. Pero
// el layout es fijo, asi que encadenamos MoveFocus (que NO hace wrap: se topa
// en el borde) para llegar SIEMPRE al panel correcto, vengas de donde vengas:
//
//   [ 1 archivos | 2 editor | 3 agente ]   (fila superior, 80%)
//   [          4 terminal           ]      (abajo, 20%, ancho completo)
//
//   1 archivos  = Up, Left, Left           (clava a la izquierda arriba)
//   2 editor    = Up, Left, Left, Right    (izquierda arriba y un paso a la der)
//   3 agente    = Up, Right, Right         (clava a la derecha arriba)
//   4 terminal  = Down                     (abajo solo hay un panel)
//
// OJO terminal: Ctrl+1..4 muchas terminales NO los mandan de forma unica
// (Ctrl+2=NUL, Ctrl+3=ESC, etc.). Por eso ALT+1..4 es lo fiable; dejamos
// tambien Ctrl+1..4 por si tu terminal (Ghostty con protocolo kitty) si los
// distingue. El foco direccional Alt+flechas / Alt+hjkl sigue siendo el default.
keybinds {
    shared_except "locked" {
        bind "Alt 1" "Ctrl 1" { MoveFocus "Up"; MoveFocus "Left"; MoveFocus "Left"; }
        bind "Alt 2" "Ctrl 2" { MoveFocus "Up"; MoveFocus "Left"; MoveFocus "Left"; MoveFocus "Right"; }
        bind "Alt 3" "Ctrl 3" { MoveFocus "Up"; MoveFocus "Right"; MoveFocus "Right"; }
        bind "Alt 4" "Ctrl 4" { MoveFocus "Down"; }
    }
}
