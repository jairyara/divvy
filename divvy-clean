#!/bin/sh
# Cleans up divvy leftovers. Two modes:
#   divvy-clean            -> reaps orphan sessions (`divvy` calls this on startup)
#   divvy-clean <session>  -> cleans that specific session
#
# With the zellij config (on_force_close "quit"), closing Ghostty already kills
# the whole session, so this is a safety belt for messy cases:
# crashes, `kill -9`, or leftovers from older versions.

# Kill by command-line pattern; TERM first, then KILL if they persist.
kill_match() {
    pids=$(pgrep -f "$1" 2>/dev/null) || return 0
    [ -z "$pids" ] && return 0
    kill $pids 2>/dev/null
    sleep 0.2
    pids=$(pgrep -f "$1" 2>/dev/null)
    [ -n "$pids" ] && kill -9 $pids 2>/dev/null
    return 0
}

clean_session() {
    s="$1"
    # nvim server (--listen, and its --embed child) and clients (--remote)
    kill_match "nvim.*--listen /tmp/divvy-${s}-nvim.sock"
    kill_match "nvim --server /tmp/divvy-${s}-nvim.sock"
    rm -f "/tmp/divvy-${s}-nvim.sock" "/tmp/divvy-${s}-edit.fifo"
}

# Dangling --remote clients from ANY divvy session: always safe to kill
# (normally they live milliseconds; if they persist, they're stuck).
kill_match "nvim --server /tmp/divvy-.*-nvim.sock --remote"

# Hung zellij actions fired by divvy-open (move-focus). Normally they live
# milliseconds; if they persist, they're orphans -> trash them.
kill_match "zellij action move-focus right"

# Specific-session mode.
if [ -n "$1" ]; then
    clean_session "$1"
    zellij delete-session "$1" --force >/dev/null 2>&1 || true
    exit 0
fi

# Reaping mode: clean divvy sessions whose zellij is no longer alive.
alive=$(zellij list-sessions -ns 2>/dev/null)
for sock in /tmp/divvy-*-nvim.sock; do
    [ -e "$sock" ] || continue
    name=${sock#/tmp/divvy-}; name=${name%-nvim.sock}
    if ! printf '%s\n' "$alive" | grep -qx "$name"; then
        clean_session "$name"
    fi
done
