#!/bin/sh
# Called by yazi when you press Enter on a file.
# Sends the path to the center-pane editor (per DIVVY_EDITOR) and
# moves focus to that pane.
# per-session paths (avoid collisions when several divvy windows are open)
SESSION="${ZELLIJ_SESSION_NAME:-default}"
SOCK="/tmp/divvy-${SESSION}-nvim.sock"
FIFO="/tmp/divvy-${SESSION}-edit.fifo"

# Portable timeout: if the editor/zellij hangs, the process does NOT become a zombie.
# Without this, a stuck nvim leaves a dangling `--remote` forever, and Enter after
# Enter piles up instances (the bug we chased down).
run_to() {
  t="$1"; shift
  if   command -v gtimeout >/dev/null 2>&1; then gtimeout "$t" "$@"
  elif command -v timeout  >/dev/null 2>&1; then timeout  "$t" "$@"
  else perl -e 'alarm shift; exec @ARGV' "$t" "$@"
  fi
}

case "${DIVVY_EDITOR:-nvim}" in
  nvim)
    # nvim runs as a server: open the file in the live instance.
    # If the server takes >5s, give up instead of hanging.
    run_to 5 nvim --server "$SOCK" --remote "$@" 2>/dev/null || true
    ;;
  *)
    # helix/micro/vim have no socket: send the path over the FIFO
    printf '%s\n' "$@" > "$FIFO" &
    ;;
esac

# move focus to the editor pane (to the right of yazi)
run_to 3 zellij action move-focus right >/dev/null 2>&1 || true
