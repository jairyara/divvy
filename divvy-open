#!/bin/sh
# Llamado por yazi al pulsar Enter sobre un archivo.
# Manda la ruta al editor del panel central (segun DIVVY_EDITOR) y
# mueve el foco a ese panel.
# paths por sesion (evita colisiones si hay varios divvy abiertos)
SESSION="${ZELLIJ_SESSION_NAME:-default}"
SOCK="/tmp/divvy-${SESSION}-nvim.sock"
FIFO="/tmp/divvy-${SESSION}-edit.fifo"

# Timeout portable: si el editor/zellij se cuelga, el proceso NO queda zombie.
# Sin esto, un nvim atascado deja un `--remote` colgado para siempre y, Enter
# tras Enter, se acumulan instancias (el bug que perseguimos).
run_to() {
  t="$1"; shift
  if   command -v gtimeout >/dev/null 2>&1; then gtimeout "$t" "$@"
  elif command -v timeout  >/dev/null 2>&1; then timeout  "$t" "$@"
  else perl -e 'alarm shift; exec @ARGV' "$t" "$@"
  fi
}

case "${DIVVY_EDITOR:-nvim}" in
  nvim)
    # nvim corre como servidor: abrimos el archivo en la instancia viva.
    # Si el server tarda >5s, abortamos en vez de colgarnos.
    run_to 5 nvim --server "$SOCK" --remote "$@" 2>/dev/null || true
    ;;
  *)
    # helix/micro/vim no tienen socket: mandamos la ruta por la FIFO
    printf '%s\n' "$@" > "$FIFO" &
    ;;
esac

# saltar el foco al panel del editor (a la derecha de yazi)
run_to 3 zellij action move-focus right >/dev/null 2>&1 || true
