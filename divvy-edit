#!/bin/sh
# Runs the editor in divvy's center pane, with its themed config (Dracula).
#  - nvim: starts as a server (yazi sends files over a socket, live).
#  - helix/micro/vim: waits for paths on a FIFO and opens the file it receives.

# resolve the real project directory (follow symlinks)
SELF="$0"
while [ -L "$SELF" ]; do
    L="$(readlink "$SELF")"
    case "$L" in
        /*) SELF="$L" ;;
        *)  SELF="$(dirname "$SELF")/$L" ;;
    esac
done
DIR="$(cd "$(dirname "$SELF")" && pwd)"

# per-session paths (avoid collisions when several divvy windows are open)
SESSION="${ZELLIJ_SESSION_NAME:-default}"
SOCK="/tmp/divvy-${SESSION}-nvim.sock"
FIFO="/tmp/divvy-${SESSION}-edit.fifo"

case "${DIVVY_EDITOR:-nvim}" in
    nvim)
        # project-isolated config
        export XDG_CONFIG_HOME="$DIR/.config"
        export XDG_DATA_HOME="$DIR/.local/share"
        export XDG_STATE_HOME="$DIR/.local/state"
        # if nvim quits (e.g. :q), it relaunches itself and listens on the socket again
        while true; do
            rm -f "$SOCK"
            nvim --listen "$SOCK"
            sleep 0.3
        done
        ;;
    helix) LABEL="helix"; run_editor() { hx --config "$DIR/helix/config.toml" "$@"; } ;;
    micro) LABEL="micro"; run_editor() { micro -config-dir "$DIR/micro" "$@"; } ;;
    vim)   LABEL="vim";   run_editor() { vim -u "$DIR/vim/vimrc" "$@"; } ;;
    *)     LABEL="${DIVVY_EDITOR}"; run_editor() { "${DIVVY_EDITOR}" "$@"; } ;;
esac

hint() {
    clear
    printf '\n  divvy · %s\n  Pick a file in yazi (left) and press Enter to edit it here.\n' "$LABEL"
}

rm -f "$FIFO"
mkfifo "$FIFO"
hint
while IFS= read -r f < "$FIFO"; do
    [ -n "$f" ] && run_editor "$f"
    hint
done
